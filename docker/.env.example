# Domain for Caddy TLS
DOMAIN=example.com

# Podman-hosted Caddy proxy targets when app/API are started on the host.
BEACON_WEB_UPSTREAM=host.docker.internal:5174
BEACON_API_UPSTREAM=host.docker.internal:8080
BEACON_WS_UPSTREAM=host.docker.internal:8080
HOST_DOCKER_INTERNAL_IP=host-gateway

# Caddy edge-proxy rate limits. These require the custom Caddy image built by
# docker-compose.yml with github.com/mholt/caddy-ratelimit.
CADDY_RATELIMIT_MODULE=github.com/mholt/caddy-ratelimit@v0.1.0
CADDY_API_RATE_LIMIT_EVENTS=600
CADDY_API_RATE_LIMIT_WINDOW=1m
CADDY_HEALTH_RATE_LIMIT_EVENTS=120
CADDY_HEALTH_RATE_LIMIT_WINDOW=1m
CADDY_WS_RATE_LIMIT_EVENTS=60
CADDY_WS_RATE_LIMIT_WINDOW=1m

# BEACON REST API base URL
VITE_API_BASE=/api/v1

# WebSocket endpoint for live packets
VITE_WS_URL=/ws

# Default map view for the "All" tab (leave both unset for a world view). VITE_MAP_CENTER is
# decimal "lat,lon", VITE_MAP_ZOOM is 0-22. The example below is a Canada-wide view.
VITE_MAP_CENTER=52.5,-96.8
VITE_MAP_ZOOM=3.2
