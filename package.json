{
  "name": "beacon-web",
  "private": true,
  "version": "1.0.0",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:analyze": "node scripts/build-analyze.mjs",
    "validate:production-image": "node scripts/validate-production-image.mjs",
    "lint": "node scripts/lint.mjs",
    "perf:budget": "node scripts/perf-budget.mjs",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:a11y": "playwright test --project=desktop --grep @a11y --workers=1",
    "test:e2e:a11y:routes": "playwright test --project=desktop --grep @a11y-route --workers=1",
    "test:e2e:a11y:styles": "playwright test --project=desktop --grep @a11y-style --workers=1",
    "test:e2e:a11y:map": "playwright test --project=desktop --grep @a11y-map --workers=1",
    "test:e2e:a11y:netgraph": "playwright test --project=desktop --grep @a11y-netgraph --workers=1",
    "preview": "vite preview",
    "start": "./scripts/devserver.sh start",
    "stop": "./scripts/devserver.sh stop",
    "restart": "./scripts/devserver.sh restart",
    "dev:status": "./scripts/devserver.sh status",
    "dev:stop-all": "./scripts/devserver.sh stop-all"
  },
  "dependencies": {
    "@nazka/map-gl-js-spiderfy": "^2.0.0",
    "@tanstack/react-query": "^5.100.11",
    "@tanstack/react-virtual": "^3.13.25",
    "@types/d3-force": "^3.0.10",
    "d3-force": "^3.0.0",
    "echarts": "5.5.1",
    "maplibre-gl": "^5.24.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.1",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.7"
  }
}
